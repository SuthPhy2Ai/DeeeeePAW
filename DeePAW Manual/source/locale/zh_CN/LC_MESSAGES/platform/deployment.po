#: ../../platform/deployment.rst:2
msgid "Local CLI Deployment"
msgstr "本地 CLI 部署"

#: ../../platform/deployment.rst:4
msgid ""
"DeePAW provides a containerized local CLI deployment, running encrypted "
"neural network model inference via Podman/Docker containers."
msgstr "DeePAW 提供容器化本地 CLI 部署方案，通过 Podman/Docker 容器运行加密神经网络模型推理。"

#: ../../platform/deployment.rst:7
msgid "Requirements"
msgstr "环境要求"

#: ../../platform/deployment.rst:9
msgid "Linux x86_64"
msgstr "Linux x86_64"

#: ../../platform/deployment.rst:10
msgid "NVIDIA GPU (CUDA support)"
msgstr "NVIDIA GPU（支持 CUDA）"

#: ../../platform/deployment.rst:11
msgid "Podman or Docker"
msgstr "Podman 或 Docker"

