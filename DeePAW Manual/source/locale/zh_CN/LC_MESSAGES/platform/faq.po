#: ../../platform/faq.rst:27
msgid "Are molecular structures supported?"
msgstr ""

#: ../../platform/faq.rst:29
msgid "Yes. When using the local CLI deployment, periodic boundary conditions must be disabled. When using the online version (deepaw.tech), setting periodic boundary conditions is not supported by default."
msgstr ""

